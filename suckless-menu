#!/usr/bin/env bash

# ============================================
# suckless-menu – manage dwm, st, dmenu, etc.
# ============================================

set -euo pipefail

# ------------------------------
# Configuration
# ------------------------------
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

EDITOR="${EDITOR:-vim}"                # change to vim, code, etc.
PATCHES_DIR="patches"                   # name of the subfolder with patch files
STATUS_FILE=".patches_applied"          # file to record applied patches

# ------------------------------
# Check required commands
# ------------------------------
if ! command -v patch &>/dev/null; then
    echo -e "\e[31mError: The 'patch' command is not installed. Install it with: sudo pacman -S patch\e[0m" >&2
    exit 1
fi

# ------------------------------
# Utility functions
# ------------------------------
error() {
    echo -e "\e[31mError: $1\e[0m" >&2
}

info() {
    echo -e "\e[32m$1\e[0m"
}

warn() {
    echo -e "\e[33mWarning: $1\e[0m"
}

# Check if a directory looks like a suckless program
is_program_dir() {
    [[ -d "$1" && -f "$1/config.def.h" && ( -f "$1/config.h" || -f "$1/config.mk" ) ]]
}

# Get list of program directories (one per line)
get_programs() {
    local dirs=()
    for d in */; do
        d="${d%/}"
        if is_program_dir "$d"; then
            dirs+=("$d")
        fi
    done
    printf "%s\n" "${dirs[@]}"
}

# Show status of a program
show_status() {
    local prog="$1"
    echo "=== Status for $prog ==="
    if [[ -f "$prog/$STATUS_FILE" ]]; then
        echo "Applied patches (in order):"
        cat "$prog/$STATUS_FILE"
    else
        echo "No patches applied."
    fi
    if [[ -d "$prog/.git" ]]; then
        echo -e "\nGit status:"
        (cd "$prog" && git status -s || true)
    fi
    echo "=========================="
}

# Ensure clean git state before patching (if repo)
ensure_clean_git() {
    local prog="$1"
    if [[ -d "$prog/.git" ]]; then
        if [[ -n "$(cd "$prog" && git status --porcelain)" ]]; then
            warn "You have uncommitted changes in $prog."
            read -p "Commit them now? (y/n/skip) [y/N] " -n 1 -r
            echo
            case "$REPLY" in
                y|Y)
                    (cd "$prog" && git add -A && git commit -m "WIP before applying patch")
                    info "Changes committed."
                    ;;
                s|S)
                    info "Skipping – changes will remain uncommitted."
                    ;;
                *)
                    warn "Aborting patch application. Please commit or stash your changes first."
                    return 1
                    ;;
            esac
        fi
    fi
    return 0
}

# Apply a patch
apply_patch() {
    local prog="$1"
    local patchfile="$2"
    local patch_name="$(basename "$patchfile")"
    local abs_patchfile="$(realpath "$patchfile")"

    # Check if already applied
    if [[ -f "$prog/$STATUS_FILE" ]] && grep -Fxq "$patch_name" "$prog/$STATUS_FILE"; then
        warn "Patch '$patch_name' already applied. Skipping."
        return 0
    fi

    # Ensure git state is clean
    ensure_clean_git "$prog" || return 1

    # Dry run
    echo "Checking patch $patch_name..."
    if (cd "$prog" && patch -p1 --dry-run -i "$abs_patchfile"); then
        # Apply cleanly
        (cd "$prog" && patch -p1 -i "$abs_patchfile")
        echo "$patch_name" >> "$prog/$STATUS_FILE"
        info "Patch '$patch_name' applied successfully."

        # Optionally commit with git
        if [[ -d "$prog/.git" ]]; then
            read -p "Commit this change? [y/N] " -n 1 -r
            echo
            if [[ $REPLY =~ ^[Yy]$ ]]; then
                (cd "$prog" && git add -A && git commit -m "apply patch: $patch_name")
            fi
        fi
    else
        error "Patch would not apply cleanly. Dry-run output shown above."
        read -p "Do you want to attempt to apply the patch anyway? (y/N) " -n 1 -r
        echo
        if [[ $REPLY =~ ^[Yy]$ ]]; then
            # Force apply
            (cd "$prog" && patch -p1 -i "$abs_patchfile")
            local ret=$?
            if [[ $ret -eq 0 ]]; then
                echo "$patch_name" >> "$prog/$STATUS_FILE"
                info "Patch '$patch_name' applied (despite previous warnings)."
                if [[ -d "$prog/.git" ]]; then
                    read -p "Commit this change? [y/N] " -n 1 -r
                    echo
                    if [[ $REPLY =~ ^[Yy]$ ]]; then
                        (cd "$prog" && git add -A && git commit -m "force apply patch: $patch_name")
                    fi
                fi
                warn "If the build fails, use the 'Revert to last commit' option to undo."
            else
                error "Patch application failed with exit code $ret. No changes were committed."
                return 1
            fi
        else
            warn "Skipped applying patch."
            return 1
        fi
    fi
}

# Revert the last patch using .patches_applied tracking
revert_last_patch() {
    local prog="$1"
    if [[ ! -f "$prog/$STATUS_FILE" ]] || [[ ! -s "$prog/$STATUS_FILE" ]]; then
        warn "No patches to revert."
        return 1
    fi
    local last_patch
    last_patch="$(tail -n 1 "$prog/$STATUS_FILE")"
    local patchfile="$prog/$PATCHES_DIR/$last_patch"
    if [[ ! -f "$patchfile" ]]; then
        error "Patch file '$last_patch' not found in $PATCHES_DIR. Cannot revert automatically."
        return 1
    fi
    local abs_patchfile="$(realpath "$patchfile")"
    if (cd "$prog" && patch -p1 -R -i "$abs_patchfile"); then
        sed -i '$d' "$prog/$STATUS_FILE"
        info "Reverted patch '$last_patch'."
        if [[ -d "$prog/.git" ]]; then
            read -p "Commit the revert? [y/N] " -n 1 -r
            echo
            if [[ $REPLY =~ ^[Yy]$ ]]; then
                (cd "$prog" && git add -A && git commit -m "revert patch: $last_patch")
            fi
        fi
    else
        error "Failed to revert patch '$last_patch'. Check manually."
        return 1
    fi
}

# Revert to last git commit (hard reset)
revert_to_last_commit() {
    local prog="$1"
    if [[ ! -d "$prog/.git" ]]; then
        error "$prog is not a git repository. Cannot revert using git."
        return 1
    fi
    warn "This will discard all uncommitted changes and reset to the last commit!"
    read -p "Are you sure? (y/N) " -n 1 -r
    echo
    if [[ $REPLY =~ ^[Yy]$ ]]; then
        (cd "$prog" && git reset --hard HEAD)
        info "Reverted to last commit."
        # Also clear the patches applied file if it exists
        if [[ -f "$prog/$STATUS_FILE" ]]; then
            rm -f "$prog/$STATUS_FILE"
            info "Removed patch tracking file."
        fi
    else
        warn "Revert cancelled."
    fi
}

# Edit config.h
edit_config() {
    local prog="$1"
    if [[ ! -f "$prog/config.h" ]]; then
        cp "$prog/config.def.h" "$prog/config.h"
    fi
    "$EDITOR" "$prog/config.h"
    if [[ -d "$prog/.git" ]]; then
        read -p "Commit config change? [y/N] " -n 1 -r
        echo
        if [[ $REPLY =~ ^[Yy]$ ]]; then
            (cd "$prog" && git add config.h && git commit -m "edit config.h")
        fi
    fi
}

# Build
do_build() {
    local prog="$1"
    (cd "$prog" && make)
    info "Build complete for $prog."
}

# Install (sudo)
do_install() {
    local prog="$1"
    (cd "$prog" && sudo make install)
    info "Installed $prog."
}

# Clean
do_clean() {
    local prog="$1"
    (cd "$prog" && make clean)
    info "Cleaned $prog."
}

# Global actions
global_build_all() {
    for prog in $(get_programs); do
        info "Building $prog..."
        (cd "$prog" && make)
    done
}

global_install_all() {
    for prog in $(get_programs); do
        info "Installing $prog..."
        (cd "$prog" && sudo make install)
    done
}

global_clean_all() {
    for prog in $(get_programs); do
        info "Cleaning $prog..."
        (cd "$prog" && make clean)
    done
}

# ------------------------------
# Program menu (actions for a specific program)
# ------------------------------
program_menu() {
    local prog="$1"
    while true; do
        echo
        echo "===== $prog ====="
        echo "1) Apply patch"
        echo "2) Edit config.h"
        echo "3) Build"
        echo "4) Install"
        echo "5) Clean"
        echo "6) Revert last patch (via patch -R)"
        echo "7) Revert to last git commit (hard reset)"
        echo "8) View status"
        echo "9) Back to main menu"
        echo "0) Exit script"
        read -p "Choose action: " action
        case "$action" in
            0)
                info "Exiting."
                exit 0
                ;;
            1) # apply patch
                if [[ ! -d "$prog/$PATCHES_DIR" ]]; then
                    error "No '$PATCHES_DIR' directory found in $prog."
                    continue
                fi
                # Collect patch files
                patch_files=()
                patch_names=()
                for f in "$prog/$PATCHES_DIR"/*.diff "$prog/$PATCHES_DIR"/*.patch; do
                    if [[ -f "$f" ]]; then
                        patch_files+=("$f")
                        patch_names+=("$(basename "$f")")
                    fi
                done
                if [[ ${#patch_files[@]} -eq 0 ]]; then
                    error "No patch files in $prog/$PATCHES_DIR."
                    continue
                fi
                echo "Available patches:"
                select name in "${patch_names[@]}" "Cancel"; do
                    if [[ "$name" == "Cancel" ]]; then
                        break
                    elif [[ -n "$name" ]]; then
                        for i in "${!patch_names[@]}"; do
                            if [[ "${patch_names[$i]}" == "$name" ]]; then
                                apply_patch "$prog" "${patch_files[$i]}"
                                break
                            fi
                        done
                        break
                    else
                        warn "Invalid selection."
                    fi
                done
                ;;
            2) edit_config "$prog" ;;
            3) do_build "$prog" ;;
            4) do_install "$prog" ;;
            5) do_clean "$prog" ;;
            6) revert_last_patch "$prog" ;;
            7) revert_to_last_commit "$prog" ;;
            8) show_status "$prog" ;;
            9) break ;;
            *) warn "Invalid choice." ;;
        esac
    done
}

# ------------------------------
# Global actions menu
# ------------------------------
global_menu() {
    while true; do
        echo
        echo "===== Global actions ====="
        echo "1) Build all programs"
        echo "2) Install all programs"
        echo "3) Clean all programs"
        echo "4) Back to main menu"
        echo "0) Exit script"
        read -p "Choose action: " action
        case "$action" in
            0)
                info "Exiting."
                exit 0
                ;;
            1) global_build_all ;;
            2) global_install_all ;;
            3) global_clean_all ;;
            4) break ;;
            *) warn "Invalid choice." ;;
        esac
    done
}

# ------------------------------
# Main menu – two‑step selection
# ------------------------------
main_menu() {
    local programs=()
    mapfile -t programs < <(get_programs)
    if [[ ${#programs[@]} -eq 0 ]]; then
        error "No suckless program directories found (missing config.def.h)."
        exit 1
    fi

    while true; do
        echo
        echo "===== suckless manager ====="
        PS3="Select a program (0 to exit): "
        select prog in "${programs[@]}" "Global actions"; do
            if [[ $REPLY == "0" ]]; then
                info "Exiting."
                exit 0
            fi
            case "$prog" in
                "Global actions")
                    global_menu
                    break
                    ;;
                "")
                    warn "Invalid selection. Please enter a number."
                    break
                    ;;
                *)
                    if [[ " ${programs[*]} " =~ " ${prog} " ]]; then
                        program_menu "$prog"
                        break
                    else
                        warn "Invalid selection. Please enter a number."
                        break
                    fi
                    ;;
            esac
        done
    done
}

# ------------------------------
# Run
# ------------------------------
main_menu
